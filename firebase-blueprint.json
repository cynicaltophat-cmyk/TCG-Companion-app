{
  "entities": {
    "Deck": {
      "title": "Deck",
      "description": "A collection of cards representing a player's deck.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "uid": { "type": "string", "description": "The owner's user ID" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "card": { "type": "object" },
              "count": { "type": "integer" },
              "artType": { "type": "string" }
            }
          }
        },
        "coverImageUrl": { "type": "string", "description": "The URL of the deck's cover image" },
        "lastModified": { "type": "integer" }
      },
      "required": ["id", "name", "uid", "items", "lastModified"]
    },
    "MatchEntry": {
      "title": "MatchEntry",
      "description": "A record of a TCG match session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "nature": { "type": "string" },
        "shopName": { "type": "string" },
        "date": { "type": "string" },
        "rounds": { "type": "array" },
        "createdAt": { "type": "integer" }
      },
      "required": ["id", "uid", "nature", "shopName", "date", "rounds", "createdAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "A user-submitted feedback ticket.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string", "description": "The user ID of the submitter" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "category": { 
          "type": "string", 
          "enum": [
            "Bug", "Feature Request", "General", "Other",
            "Incorrect ability effect", "Incorrect color", "Incorrect/Missing links",
            "Incorrect stats", "Incorrect ID number", "Incorrect trait"
          ] 
        },
        "message": { "type": "string" },
        "cardId": { "type": "string", "description": "Optional card ID if feedback is about a specific card" },
        "cardName": { "type": "string", "description": "Optional card name" },
        "createdAt": { "type": "integer" },
        "status": { "type": "string", "enum": ["New", "In Progress", "Resolved", "Closed"] }
      },
      "required": ["uid", "category", "message", "createdAt", "status"]
    },
    "Card": {
      "title": "Card",
      "description": "A single card in the Gundam TCG.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "set": { "type": "string" },
        "cardNumber": { "type": "string" },
        "type": { "type": "string", "enum": ["Unit", "Pilot", "Command", "Base"] },
        "color": { "type": "string", "enum": ["Red", "Blue", "Green", "White", "Black", "Yellow", "Purple"] },
        "rarity": { "type": "string", "enum": ["C", "U", "R", "SR", "UR", "LR"] },
        "cost": { "type": "integer" },
        "level": { "type": "integer" },
        "ap": { "type": "integer" },
        "hp": { "type": "integer" },
        "ability": { "type": "string" },
        "imageUrl": { "type": "string" },
        "baseArtist": { "type": "string" },
        "baseArtistLink": { "type": "string" },
        "altImageUrl": { "type": "string" },
        "altArtist": { "type": "string" },
        "altArtistLink": { "type": "string" },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "imageUrl": { "type": "string" },
              "artist": { "type": "string" },
              "artistLink": { "type": "string" }
            }
          }
        },
        "traits": { "type": "array", "items": { "type": "string" } },
        "link": { "type": "string" },
        "faq": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "answer": { "type": "string" }
            },
            "required": ["question", "answer"]
          }
        }
      },
      "required": ["id", "name", "set", "cardNumber", "type", "color", "rarity", "cost", "ability", "imageUrl"]
    },
    "Bookmark": {
      "title": "Bookmark",
      "description": "A user's bookmarked card.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the owner" },
        "cardId": { "type": "string", "description": "The ID of the bookmarked card" },
        "createdAt": { "type": "integer" }
      },
      "required": ["uid", "cardId", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A TCG product listing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Starter Deck", "Booster box", "Other"] },
        "imageUrl": { "type": "string" },
        "releaseDate": { "type": "string" },
        "msrp": { "type": "string" },
        "whereToBuy": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "featuredCards": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "cardId": { "type": "string" },
              "count": { "type": "integer" }
            }
          }
        },
        "contents": { "type": "array", "items": { "type": "string" } },
        "order": { "type": "integer", "description": "Sort order for display" }
      },
      "required": ["id", "name", "category", "imageUrl", "releaseDate", "msrp"]
    }
  },
  "firestore": {
    "decks/{deckId}": {
      "schema": "Deck",
      "description": "User created decks"
    },
    "matches/{matchId}": {
      "schema": "MatchEntry",
      "description": "User match history"
    },
    "feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback tickets"
    },
    "card_feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "Specific card feedback tickets"
    },
    "cards/{cardId}": {
      "schema": "Card",
      "description": "The master list of all cards"
    },
    "bookmarks/{bookmarkId}": {
      "schema": "Bookmark",
      "description": "User bookmarked cards"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Product listings for the TCG"
    }
  }
}
