rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: decks
    // Fields:
    //   - id: string (required)
    //   - name: string (required, 1-100 chars)
    //   - uid: string (required, immutable)
    //   - items: list (required, max 100 items)
    //   - coverImageUrl: string (optional)
    //   - lastModified: int (required)
    //
    // Collection: matches
    // Fields:
    //   - id: string (required)
    //   - uid: string (required, immutable)
    //   - nature: string (required)
    //   - shopName: string (required)
    //   - date: string (required)
    //   - rounds: list (required)
    //   - createdAt: int (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.email_verified == true &&
        request.auth.token.email.matches("(?i)^(inkytophat|cynicaltophat|angkaiyan)@gmail\\.com$");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return fields.hasAll(request.resource.data.keys());
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidDeck(data) {
      return hasOnlyAllowedFields(['id', 'name', 'uid', 'items', 'coverImageUrl', 'lastModified', 'folderId']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.uid is string && data.uid == request.auth.uid &&
             data.items is list && data.items.size() <= 100 &&
             (!('coverImageUrl' in data) || (data.coverImageUrl is string && data.coverImageUrl.size() <= 2000)) &&
             (!('folderId' in data) || (data.folderId == null || (data.folderId is string && data.folderId.size() <= 128))) &&
             data.lastModified is int;
    }

    function isValidDeckFolder(data) {
      return hasOnlyAllowedFields(['id', 'uid', 'name', 'icon', 'createdAt']) &&
             data.id is string &&
             data.uid is string && data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('icon' in data) || (data.icon is string && data.icon.size() <= 100)) &&
             data.createdAt is int;
    }

    function isValidMatch(data) {
      return hasOnlyAllowedFields(['id', 'uid', 'nature', 'shopName', 'date', 'rounds', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.nature is string &&
             data.shopName is string &&
             data.date is string &&
             data.rounds is list &&
             data.createdAt is int;
    }

    function isValidFeedback(data) {
      return hasOnlyAllowedFields(['id', 'uid', 'userEmail', 'userName', 'category', 'message', 'cardId', 'cardName', 'createdAt', 'status']) &&
             data.uid is string &&
             (data.userEmail == null || data.userEmail is string) &&
             (data.userName == null || data.userName is string) &&
             data.category in [
               'Bug', 'Feature Request', 'General', 'Other',
               'Incorrect ability effect', 'Incorrect color', 'Incorrect/Missing links',
               'Incorrect stats', 'Incorrect ID number', 'Incorrect trait'
             ] &&
             data.message is string && data.message.size() <= 2000 &&
             data.createdAt is int &&
             data.status in ['New', 'In Progress', 'Resolved', 'Closed'];
    }

    function isValidCard(data) {
      // Relaxed validation to ensure migration works
      return data.id is string &&
             data.name is string &&
             data.cardNumber is string;
    }

    function isValidBookmark(data) {
      return hasOnlyAllowedFields(['uid', 'cardId', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.cardId is string &&
             data.createdAt is int;
    }


    function isValidTournamentEvent(data) {
      return hasOnlyAllowedFields(['id', 'name', 'season', 'date', 'type']) &&
             data.id is string &&
             data.name is string &&
             data.season is string &&
             data.date is string &&
             data.type == 'Organized Event';
    }

    function isValidDeckSubmission(data) {
      return hasOnlyAllowedFields(['id', 'uid', 'deckId', 'deckName', 'deckItems', 'coverImageUrl', 'playerName', 'season', 'eventType', 'tournamentId', 'tournamentName', 'date', 'placement', 'createdAt', 'updatedAt', 'status']) &&
             data.id is string &&
             data.uid is string &&
             data.deckId is string &&
             data.deckName is string &&
             data.deckItems is list &&
             data.playerName is string &&
             data.season is string &&
             data.eventType in ['Shop Battle', 'Newtype challenge', 'Organized Event'] &&
             (!('tournamentId' in data) || (data.tournamentId is string || data.tournamentId == null)) &&
             (!('tournamentName' in data) || (data.tournamentName is string || data.tournamentName == null)) &&
             data.date is string &&
             data.placement.matches('^Top ([1-9]|[12][0-9]|3[0-2])$') &&
             data.createdAt is int &&
             (!('updatedAt' in data) || (data.updatedAt is string || data.updatedAt is int)) &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    function isValidShortLink(data) {
      return hasOnlyAllowedFields(['id', 'deckData', 'createdAt']) &&
             data.id is string &&
             data.deckData is map &&
             data.createdAt is int;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /short_links/{shortId} {
      allow read: if true;
      allow create: if isValidShortLink(request.resource.data);
    }

    match /cards/{cardId} {
      allow read: if true; // Cards are public
      allow write: if isAdmin(); // Only admins can manage cards
    }


    match /tournament_events/{eventId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidTournamentEvent(request.resource.data);
      allow delete: if isAdmin();
    }

    match /deck_submissions/{submissionId} {
      allow read, list: if (resource.data.status == 'approved') || isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidDeckSubmission(request.resource.data) && request.resource.data.status == 'pending' && request.resource.data.uid == request.auth.uid;
      allow update: if (isAdmin() && isValidDeckSubmission(request.resource.data)) || (isDocOwner() && resource.data.status == 'pending' && isValidDeckSubmission(request.resource.data) && request.resource.data.status == 'pending' && request.resource.data.uid == resource.data.uid);
      allow delete: if isAdmin() || (isDocOwner() && resource.data.status == 'pending');
    }

    match /deck_folders/{folderId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidDeckFolder(request.resource.data);
      allow update: if isDocOwner() && isValidDeckFolder(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /decks/{deckId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidDeck(request.resource.data);
      allow update: if isDocOwner() && isValidDeck(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /matches/{matchId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidMatch(request.resource.data);
      allow update: if isDocOwner() && isValidMatch(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /feedback/{feedbackId} {
      // Users can only read their own feedback, admins can read all
      allow read: if isDocOwner() || isAdmin();
      // Any user can create feedback
      allow create: if isValidFeedback(request.resource.data) && (
        (isAuthenticated() && request.resource.data.uid == request.auth.uid) ||
        (request.resource.data.uid == 'anonymous')
      );
      // Only admins can update feedback (e.g., change status)
      allow update: if isAdmin() && isValidFeedback(request.resource.data);
      // Only admins can delete feedback
      allow delete: if isAdmin();
    }

    match /card_feedback/{feedbackId} {
      // Users can only read their own feedback, admins can read all
      allow read: if isDocOwner() || isAdmin();
      // Any user can create feedback
      allow create: if isValidFeedback(request.resource.data) && (
        (isAuthenticated() && request.resource.data.uid == request.auth.uid) ||
        (request.resource.data.uid == 'anonymous')
      );
      // Only admins can update feedback (e.g., change status)
      allow update: if isAdmin() && isValidFeedback(request.resource.data);
      // Only admins can delete feedback
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /bookmarks/{bookmarkId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidBookmark(request.resource.data) && bookmarkId == request.auth.uid + "_" + request.resource.data.cardId;
      allow delete: if isDocOwner();
    }
  }
}
