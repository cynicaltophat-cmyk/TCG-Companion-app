rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: decks
    // Fields:
    //   - id: string (required)
    //   - name: string (required, 1-100 chars)
    //   - uid: string (required, immutable)
    //   - items: list (required, max 100 items)
    //   - coverImageUrl: string (optional)
    //   - lastModified: int (required)
    //
    // Collection: matches
    // Fields:
    //   - id: string (required)
    //   - uid: string (required, immutable)
    //   - nature: string (required)
    //   - shopName: string (required)
    //   - date: string (required)
    //   - rounds: list (required)
    //   - createdAt: int (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.email.matches("(?i)^(inkytophat|cynicaltophat)@gmail\\.com$");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidDeck(data) {
      return hasOnlyAllowedFields(['id', 'name', 'uid', 'items', 'coverImageUrl', 'lastModified']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.uid is string && data.uid == request.auth.uid &&
             data.items is list && data.items.size() <= 100 &&
             (!('coverImageUrl' in data) || (data.coverImageUrl is string && data.coverImageUrl.size() <= 2000)) &&
             data.lastModified is int;
    }

    function isValidMatch(data) {
      return hasOnlyAllowedFields(['id', 'uid', 'nature', 'shopName', 'date', 'rounds', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.nature is string &&
             data.shopName is string &&
             data.date is string &&
             data.rounds is list &&
             data.createdAt is int;
    }

    function isValidFeedback(data) {
      return hasOnlyAllowedFields(['id', 'uid', 'userEmail', 'userName', 'category', 'message', 'cardId', 'cardName', 'createdAt', 'status']) &&
             (
               (isAuthenticated() && data.uid == request.auth.uid) ||
               (!isAuthenticated() && data.uid == 'anonymous')
             ) &&
             data.category in [
               'Bug', 'Feature Request', 'General', 'Other',
               'Incorrect ability effect', 'Incorrect color', 'Incorrect/Missing links',
               'Incorrect stats', 'Incorrect ID number', 'Incorrect trait'
             ] &&
             data.message is string && data.message.size() >= 0 && data.message.size() <= 2000 &&
             data.createdAt is int &&
             data.status in ['New', 'In Progress', 'Resolved', 'Closed'];
    }

    function isValidCard(data) {
      // Relaxed validation to ensure migration works
      return data.id is string &&
             data.name is string &&
             data.cardNumber is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /cards/{cardId} {
      allow read: if true; // Cards are public
      allow write: if isAdmin(); // Only admins can manage cards
    }

    match /decks/{deckId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidDeck(request.resource.data);
      allow update: if isDocOwner() && isValidDeck(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /matches/{matchId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidMatch(request.resource.data);
      allow update: if isDocOwner() && isValidMatch(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /feedback/{feedbackId} {
      // Users can only read their own feedback, admins can read all
      allow read: if isDocOwner() || isAdmin();
      // Any user can create feedback
      allow create: if isValidFeedback(request.resource.data);
      // Only admins can update feedback (e.g., change status)
      allow update: if isAdmin() && isValidFeedback(request.resource.data);
      // Only admins can delete feedback
      allow delete: if isAdmin();
    }

    match /card_feedback/{feedbackId} {
      // Users can only read their own feedback, admins can read all
      allow read: if isDocOwner() || isAdmin();
      // Any user can create feedback
      allow create: if isValidFeedback(request.resource.data);
      // Only admins can update feedback (e.g., change status)
      allow update: if isAdmin() && isValidFeedback(request.resource.data);
      // Only admins can delete feedback
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
